#!/bin/bash

# ==============================================================================
# JARVIS: CENTRAL AUDIO ARBITRATOR & PREEMPTION ENGINE
# ==============================================================================

LOCK_FILE="/tmp/jarvis_audio.lock"
PIPER_DIR="$HOME/.local/piper"
MODEL="$PIPER_DIR/en_GB-alan-medium.onnx"
AUDIO_RATE="22050"

USAGE="Usage: jarvis_say [--critical] \"Message text\""

if [ $# -eq 0 ]; then
    echo "$USAGE"
    exit 1
fi

PRIORITY="NORMAL"
if [ "$1" == "--critical" ]; then
    PRIORITY="CRITICAL"
    shift
fi

# Clean the text of markdown/code that breaks Piper
TEXT=$(echo "$1" | sed -e 's/"//g' -e "s/'//g" -e 's/`//g' -e 's/\*//g' | tr '\n' ' ')
if [ -z "$TEXT" ]; then
    exit 0
fi

# ------------------------------------------------------------------------------
# FUNCTION: EXECUTE SPEECH PIPELINE
# ------------------------------------------------------------------------------
execute_speech() {
    echo "$TEXT" | "$PIPER_DIR/piper" --model "$MODEL" --length_scale 0.85 --output_raw 2>/dev/null | aplay -r "$AUDIO_RATE" -f S16_LE -t raw -q
}

# ------------------------------------------------------------------------------
# CRITICAL PATHWAY (Preemption + Pipewire Mute Bypass)
# ------------------------------------------------------------------------------
if [ "$PRIORITY" == "CRITICAL" ]; then
    # 1. Clear the deck: Kill any current voice instances immediately
    pkill -f piper 2>/dev/null
    pkill -f aplay 2>/dev/null
    
    # 2. Capture hardware mixer states using wpctl (Parrot OS 6+ native)
    # Get volume percentage (e.g., 0.45)
    VOL_LEVEL=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2}')
    # Check if muted (wpctl appends [MUTED] if true)
    MUTED=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -o "\[MUTED\]")

    # 3. Force Unmute & set minimum audible threshold if system is silenced
    if [ -n "$MUTED" ] || (( $(echo "$VOL_LEVEL < 0.15" | bc -l) )); then
        wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 >/dev/null 2>&1
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.40 >/dev/null 2>&1
        RESTORE_AUDIO=true
    else
        RESTORE_AUDIO=false
    fi

    # 4. Ducking Protocol: Isolate background apps (VLC, Chrome) and reduce to 10%
    declare -A DUCKED_STREAMS
    CURRENT_SINK_ID=""
    
    while IFS= read -r line; do
        if [[ "$line" == Sink\ Input\ #* ]]; then
            CURRENT_SINK_ID="${line#Sink Input #}"
        elif [[ "$line" == *Volume:* ]] && [ -n "$CURRENT_SINK_ID" ]; then
            # Extract the first volume percentage (e.g., 70%)
            VOL_PCT=$(echo "$line" | grep -oP '\d+%' | head -n 1)
            if [ -n "$VOL_PCT" ]; then
                # Save the original volume to memory
                DUCKED_STREAMS["$CURRENT_SINK_ID"]="$VOL_PCT"
                # Instantly crush the background app to 10%
                pactl set-sink-input-volume "$CURRENT_SINK_ID" 10% >/dev/null 2>&1
            fi
            CURRENT_SINK_ID=""
        fi
    done <<< "$(pactl list sink-inputs 2>/dev/null)"

    # 5. Speak immediately, overriding locks
    execute_speech

    # 6. Restore ducked background streams to their exact original volumes
    for SINK_ID in "${!DUCKED_STREAMS[@]}"; do
        ORIG_VOL="${DUCKED_STREAMS[$SINK_ID]}"
        pactl set-sink-input-volume "$SINK_ID" "$ORIG_VOL" >/dev/null 2>&1
    done

    # 7. Restore master volume state exactly
    if [ "$RESTORE_AUDIO" = true ]; then
        wpctl set-volume @DEFAULT_AUDIO_SINK@ "$VOL_LEVEL" >/dev/null 2>&1
        if [ -n "$MUTED" ]; then
            wpctl set-mute @DEFAULT_AUDIO_SINK@ 1 >/dev/null 2>&1
        fi
    fi

# ------------------------------------------------------------------------------
# NORMAL PATHWAY (Sequential Queue via File Locking)
# ------------------------------------------------------------------------------
else
    # Acquire exclusive lock. If another script is speaking, wait natively in line.
    exec 9>"$LOCK_FILE"
    flock 9
    
    execute_speech
    
    # Release lock implicitly on exit
fi